{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "DataGuard Pipeline Sentinel — MCP tool latency, LLM usage, adapter health, quality detectors",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "MCP Tools",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (tool, le) (rate(sentinel_mcp_tool_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{tool}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (tool, le) (rate(sentinel_mcp_tool_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{tool}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (tool, le) (rate(sentinel_mcp_tool_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{tool}}",
          "refId": "C"
        }
      ],
      "title": "MCP Tool Latency (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum by (tool) (rate(sentinel_mcp_tool_duration_seconds_count[5m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "title": "MCP Tool Call Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "sum by (tool, error_type) (rate(sentinel_mcp_tool_errors_total[5m]))",
          "legendFormat": "{{tool}} / {{error_type}}",
          "refId": "A"
        }
      ],
      "title": "MCP Tool Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "sum by (tool) (rate(sentinel_mcp_tool_errors_total[5m])) / sum by (tool) (rate(sentinel_mcp_tool_duration_seconds_count[5m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "title": "MCP Tool Error Ratio",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "LLM Usage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (direction, model) (rate(sentinel_llm_tokens_total[5m]))",
          "legendFormat": "{{direction}} / {{model}}",
          "refId": "A"
        }
      ],
      "title": "LLM Token Rate (input / output)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (pattern) (rate(sentinel_llm_deterministic_hits_total[5m]))",
          "legendFormat": "{{pattern}}",
          "refId": "A"
        }
      ],
      "title": "Deterministic Pattern Hits (LLM bypassed)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 26 },
      "id": 7,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "expr": "sum(rate(sentinel_llm_deterministic_hits_total[5m])) / (sum(rate(sentinel_llm_deterministic_hits_total[5m])) + sum(rate(sentinel_mcp_tool_duration_seconds_count{tool='diagnose_failure'}[5m])))",
          "legendFormat": "Deterministic hit rate",
          "refId": "A"
        }
      ],
      "title": "Pattern Match Rate (LLM bypass %)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 18, "x": 6, "y": 26 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "expr": "sum by (direction) (increase(sentinel_llm_tokens_total[24h]))",
          "legendFormat": "{{direction}} tokens (24h)",
          "refId": "A"
        }
      ],
      "title": "Total LLM Tokens (24h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 102,
      "title": "Orchestrator Adapters",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 9,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (adapter, operation, le) (rate(sentinel_adapter_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{adapter}} / {{operation}}",
          "refId": "A"
        }
      ],
      "title": "Adapter Request Latency p95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 10,
      "targets": [
        {
          "expr": "sum by (adapter, operation) (rate(sentinel_adapter_request_duration_seconds_count[5m]))",
          "legendFormat": "{{adapter}} / {{operation}}",
          "refId": "A"
        }
      ],
      "title": "Adapter Request Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 103,
      "title": "Quality Detectors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "id": 11,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (detector, le) (rate(sentinel_detector_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{detector}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (detector, le) (rate(sentinel_detector_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{detector}}",
          "refId": "B"
        }
      ],
      "title": "Detector Run Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "id": 12,
      "targets": [
        {
          "expr": "sum by (detector) (rate(sentinel_detector_duration_seconds_count[5m]))",
          "legendFormat": "{{detector}}",
          "refId": "A"
        }
      ],
      "title": "Detector Invocation Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["dataguard", "pipeline", "mcp", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DataGuard — Pipeline Sentinel",
  "uid": "dataguard-pipeline-sentinel",
  "version": 1
}
